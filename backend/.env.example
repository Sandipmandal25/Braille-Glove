# Copy this file to .env and fill in your values

# Required — get from @BotFather on Telegram
TELEGRAM_TOKEN=your-telegram-bot-token-here

# Comma-separated Telegram user IDs that are allowed to send messages
# Leave empty to accept messages from anyone (not recommended)
TELEGRAM_ALLOWED_IDS=[123456789,987654321]

# SQLite database path (relative to backend/)
DATABASE_URL=sqlite+aiosqlite:///./braille_glove.db

# BLE scan timeout in seconds
BLE_SCAN_TIMEOUT=10.0

# REST API bind address
API_HOST=0.0.0.0
API_PORT=8000
